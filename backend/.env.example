# Cardoria V5 — Variables d'environnement production
# Copier vers Render / .env local backend

NODE_ENV=production
APP_VERSION=1.0.0
PORT=10000

# ── Sécurité ──
ADMIN_CODE=
LEGACY_ADMIN_CODE=true
ADMIN_EMAIL=Cardoria59330@gmail.com
ADMIN_INITIAL_PASSWORD=
SESSION_HOURS=12
CSRF_ENABLED=false
CORS_ORIGINS=https://cardoria.fr,https://www.cardoria.fr,https://cardoria.vercel.app
BODY_LIMIT=15mb
RATE_LIMIT_API=120
RATE_LIMIT_AUTH=10
RATE_LIMIT_AI=8
BRUTE_FORCE_MAX=5
ALERT_EMAIL=true

# ── Base de données ──
DATABASE_URL=
USE_POSTGRES=false
PG_SSL=true
PG_POOL_MAX=10

# ── Sauvegardes ──
BACKUP_INTERVAL_HOURS=24
BACKUP_MAX_KEEP=14

# ── Lancement V1.0 ──
JOURNAL_MAX_LINES=10000
HEALTH_ALERT_INTERVAL_MS=900000
ALERT_COOLDOWN_MS=3600000

# ── OpenAI ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
CONFIDENCE_THRESHOLD=95
AI_ENTERPRISE_WORKER_MS=900000

# ── Ultimate Enterprise (Étape 16) ──
ULTIMATE_WORKER_MS=1200000

# ── Big Data Engine ──
BIGDATA_WORKER_MS=1500000

# ── Email ──
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_TO=Cardoria59330@gmail.com

# ── SumUp ──
SUMUP_API_KEY=
SUMUP_MERCHANT_CODE=
SUMUP_WEBHOOK_SECRET=
SUMUP_RETURN_URL=
BOUTIQUE_SUCCESS_URL=https://cardoria.fr/boutique.html
MARKETPLACE_SUCCESS_URL=https://cardoria.fr/marketplace-paiement-succes.html
MARKETPLACE_CANCEL_URL=https://cardoria.fr/marketplace-paiement-echec.html
MARKETPLACE_VAT_RATE=20
MARKETPLACE_FRONTEND_URL=https://cardoria.fr

# ── Site & SEO ──
SITE_URL=https://cardoria.fr
GA4_MEASUREMENT_ID=
CLARITY_PROJECT_ID=
GSC_VERIFIED=false

# ── Cache ──
CACHE_TTL_MS=60000

# ── Scanner IA ──
SCANNER_MAX_IMAGES=6

# ── Shipping APIs (optionnel) ──
MONDIAL_RELAY_API_KEY=
