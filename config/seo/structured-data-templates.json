    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Cardoria",
    "url": "https://cardoria.fr",
    "logo": "https://cardoria.fr/assets/logo/cardoria-premium.png",
    "email": "Cardoria59330@gmail.com",
    "sameAs": []
  },
  "website": {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Cardoria",
